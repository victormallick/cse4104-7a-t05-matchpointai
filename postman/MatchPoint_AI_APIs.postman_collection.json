		{
			"name": "3. File Operations",
			"item": [
				{
					"name": "Upload Resume",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const responseJson = pm.response.json();",
									"if (responseJson && responseJson.success && responseJson.data) {",
									"    const resumeId = responseJson.data.resume_id;",
									"    pm.collectionVariables.set(\"resume_id\", resumeId);",
									"    console.log(\"Saved resume_id to collection variables.\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-User-Id",
								"value": "{{user_id}}",
								"type": "text",
								"description": "Alternative to body parameter user_id"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "resume",
									"type": "file",
									"src": [],
									"description": "Attach a PDF, DOCX, or TXT file"
								},
								{
									"key": "user_id",
									"value": "{{user_id}}",
									"type": "text",
									"description": "User id context"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/upload",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"upload"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "4. Gap Analysis & History",
			"item": [
				{
					"name": "Trigger Gap Analysis",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const responseJson = pm.response.json();",
									"if (responseJson && responseJson.success && responseJson.data) {",
									"    const analysisId = responseJson.data.analysis_id;",
									"    pm.collectionVariables.set(\"analysis_id\", analysisId);",
