						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"resume_id\": \"{{resume_id}}\",\n  \"jd_text\": \"We are looking for a Senior Software Engineer with strong skills in Node.js, Express, TypeScript, and Docker containerization. Experience running database migrations in PostgreSQL or Supabase is preferred. Understanding of Redis caching is a major plus.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/analysis/gap-analysis",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
